build() {
  cd "$srcdir"
  make -B SRCDIR=. HOOKSDIR=. THIRDPARTY=.
}

check() {
  cd "$srcdir"
  make test SRCDIR=. HOOKSDIR=. THIRDPARTY=.
}

package() {
  install -Dm755 "$srcdir/envwalk" "$pkgdir/usr/bin/envwalk"
}
