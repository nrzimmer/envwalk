pkgname=envwalk
pkgver=0.2
pkgrel=1
pkgdesc="Per-directory .env loader for zsh and bash"
arch=('x86_64')
license=('MIT')
changelog='CHANGELOG'

source=(
  "cli.c"
  "cli.h"
  "config.c"
  "config.h"
  "dotenv.c"
  "dotenv.h"
  "path.c"
  "path.h"
  "types.c"
  "types.h"
  "envwalk.c"
  "stack_trace.c"
  "stack_trace.h"
  "test.c"
  "nob.h"
  "Makefile"
  "hook.zsh"
  "hook.bash"
)

